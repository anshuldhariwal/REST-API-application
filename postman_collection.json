{
  "info": {
    "name": "Backend Assignment API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseurl",
      "value": "http://localhost:3001"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "teacherId",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    },
    {
      "key": "dateTimestamp",
      "value": "1782950400000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseurl}}/health"
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Anshul Dhariwal\",\n  \"email\": \"anshul@example.com\",\n  \"phone\": \"9999999999\"\n}"
        },
        "url": "{{baseurl}}/users"
      }
    },
    {
      "name": "Create Teacher",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Riya Mehta\",\n  \"email\": \"riya@example.com\",\n  \"specialization\": \"Mathematics\",\n  \"experience\": 6\n}"
        },
        "url": "{{baseurl}}/teachers"
      }
    },
    {
      "name": "Create Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"startTime\": \"2026-07-02T10:00:00.000Z\",\n  \"endTime\": \"2026-07-02T11:00:00.000Z\"\n}"
        },
        "url": "{{baseurl}}/sessions"
      }
    },
    {
      "name": "Available Sessions",
      "request": {
        "method": "GET",
        "url": "{{baseurl}}/sessions/available?dateTimestamp={{dateTimestamp}}"
      }
    },
    {
      "name": "Book Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
        },
        "url": "{{baseurl}}/sessions/{{sessionId}}/book"
      }
    },
    {
      "name": "Complete Session",
      "request": {
        "method": "PATCH",
        "url": "{{baseurl}}/sessions/{{sessionId}}/complete"
      }
    },
    {
      "name": "User Sessions",
      "request": {
        "method": "GET",
        "url": "{{baseurl}}/users/{{userId}}/sessions"
      }
    }
  ]
}
